EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Optional: enables WeatherAPI.com as primary weather provider.
# If omitted, the app falls back to Open-Meteo.
EXPO_PUBLIC_WEATHERAPI_KEY=your-weatherapi-key

# Server-side only (Supabase Edge Function secrets). Do not expose to client app.
OPENAI_API_KEY=your-openai-api-key
HF_TOKEN=your-huggingface-token
OPENAI_VISION_MODEL=gpt-5.4-mini
OPENAI_STYLIST_MODEL=gpt-5.4-mini

